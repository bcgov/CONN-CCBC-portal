{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "outDir": "dist",
    "target": "es2017",
    "isolatedModules": false,
    "noEmit": false
  },
  "include": [
    "server.ts",
    "backend/**/*.ts",
    "lib/**/*.ts",
    "data/**/*",
    "styles/theme.ts",
    "styles/styled.d.ts"
  ],
  "exclude": ["node_modules"]
}
